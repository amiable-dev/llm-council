# llm_council.yaml — configuration template (copy to ./llm_council.yaml or
# ~/.config/llm-council/llm_council.yaml, or point LLM_COUNCIL_CONFIG at it).
# Priority: YAML > environment variables > defaults (ADR-024/031/032).
# ${VAR} substitution is supported. Full env-var reference:
# https://llm-council.dev/reference/environment-variables/

council:
  # models: [openai/gpt-5.4, google/gemini-3.1-pro-preview, anthropic/claude-opus-4.8, deepseek/deepseek-v4-pro]
  # chairman: google/gemini-3.1-pro-preview
  synthesis_mode: consensus        # consensus | debate
  exclude_self_votes: true
  style_normalization: false

tiers:
  default: high                    # quick | balanced | high | reasoning
  # pools:
  #   quick:    {models: [...], timeout_seconds: 30}
  #   balanced: {models: [...], timeout_seconds: 90}

gateways:
  enabled: false                   # circuit breaker + multi-router (ADR-023)
  # default: openrouter            # openrouter | requesty | direct

triage:
  enabled: false                   # L2 domain triage (ADR-020)
  # fast_path: {enabled: false, confidence_threshold: 0.92}

evaluation:
  rubric:
    enabled: false                 # multi-dimensional scoring (ADR-016)
  safety:
    enabled: false                 # safety pre-check gate (ADR-016)
  bias:
    enabled: false                 # per-session bias audit (ADR-015)
    # store_path: data/bias_metrics.jsonl
    # consent_level: LOCAL_ONLY    # OFF|LOCAL_ONLY|ANONYMOUS|ENHANCED|RESEARCH

metrics:
  enabled: false                   # ADR-030: none | statsd | prometheus
  # backend: statsd
